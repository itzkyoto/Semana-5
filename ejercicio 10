public class Ejercicio10 : MonoBehaviour
{
    bool VeoJugador;
    bool PlayerNearby;
    string Estado;
    
    
    
    
    
    
    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        if (VeoJugador && PlayerNearby)
        {
            Debug.Log(Estado = ("Atacando"));
        }
        else if (VeoJugador && !PlayerNearby)
        {
            Debug.Log(Estado = ("Perseguir"));
        }
        else if (!VeoJugador)
        {
            Debug.Log(Estado = ("Patrullar"));
        }

        Estado = VeoJugador ? PlayerNearby?  "Atacamos": "Perseguir" : "patrullar";

    }

    // Update is called once per frame
    void Update()
    {
        
    }
}
